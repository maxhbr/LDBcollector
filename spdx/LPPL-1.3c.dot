    12326 [label="ChooseALicense:\nThe LaTeX Project Public License (LPPL) is the primary license under which the\nLaTeX kernel and the base LaTeX packages are distributed."
          ,fillcolor="beige;1"
          ,shape=plaintext];
    12327 [label="ChooseALicense:\nHow to apply this license:\nPlace in each of the components of your work both an explicit copyright notice\nincluding your name, and the year the work was authored and/or last\nsubstantially modified. Include also a statement that the distribution and/or\nmodification of that component is constrained by the conditions in this license."
          ,fillcolor="beige;1"
          ,shape=plaintext];
    12328 [label=<<TABLE><TR><TD>Permissions</TD> <TD>Conditions</TD> <TD>Limitations</TD> <TD>Restrictions</TD></TR>
                         <TR><TD>commercial-use<BR />modifications<BR />distribution<BR />private-use</TD> <TD>include-copyright<BR />document-changes<BR />disclose-source</TD> <TD>liability<BR />warranty</TD> <TD></TD></TR></TABLE>>
          ,fillcolor="beige;1"
          ,shape=plaintext];

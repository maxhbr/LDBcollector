    40001 [label="LicenseTag (ScopedLicenseTag \"OrtLicenseCategorization\" \"property:include-in-notice-file\" (LicenseTagDescription \"Whether the license includes a notice obligation or similar which can be fulfilled by adding the relevant copyright notices and the license text into the project/product notice file.\"))"

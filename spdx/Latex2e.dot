    40020 [label="LicenseTag (ScopedLicenseTag \"OrtLicenseCategorization\" \"copyleft-module-level\" (LicenseTagDescription \"Open source license that requires you to license modifications made into the same software module with the same license as the original open source software module. This also applies, if you add code from this module to your own module. Examples: EPL-1.1, CPL-1.0.\"))"
          ,fillcolor="beige;1"

    61482 [label="HitachiOpenLicense:\nVenue shall be within Santa Clara County, California, and subject to the\nprovisions of California law, the Federal Court for the Northern District of\nCalifornia, and the jurisdiction of the state courts of California CDDL-1.0"
          ,fillcolor="beige;1"
          ,shape=plaintext];

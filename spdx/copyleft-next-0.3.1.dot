    40002 [label="LicenseTag (ScopedLicenseTag \"OrtLicenseCategorization\" \"include-in-notice-file\" (LicenseTagDescription \"Same as above, as a temporary work-around for the category name not being configurable in ORT reports, see https://github.com/oss-review-toolkit/ort/issues/8220.\"))"
          ,fillcolor="beige;1"
          ,shape=plaintext];
    40006 [label="LicenseTag (ScopedLicenseTag \"OrtLicenseCategorization\" \"property:distribute-source-code\" (LicenseTagDescription \"This property indicates that the license requires that the source code of the OSS is either distributed, or offered to distribute, in connection with the software delivery.\"))"
          ,fillcolor="beige;1"
          ,shape=plaintext];
    40011 [label="LicenseTag (ScopedLicenseTag \"OrtLicenseCategorization\" \"copyleft-strong\" (LicenseTagDescription \"Open source license that requires you to license modifications, as well as any code that ends up in the same binary (including static linking and module modifications), as well as other code that is part of the same work, with the same strong copyleft license. Examples: GPL-2.0, GPL-3.0, AGPL-3.0, EUPL-1.0, EUPL-1.1, EUPL-1.2.\"))"
          ,fillcolor="beige;1"
          ,shape=plaintext];
    40132 [label="LicenseTag (ScopedLicenseTag \"OrtLicenseCategorization\" \"property:unchecked\" (LicenseTagDescription \"This property marking means that the properties of the license have not been checked. Ask for license categorization/checking. This typically is an uncommon license, which has not yet been fully categorized.\"))"
          ,fillcolor="beige;1"

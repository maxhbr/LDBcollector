    2629 [label="SPDXLicense:\nThe ImageMagick license is nearly identical to the Apache-2.0 license. The\ndifferences are the title and additional preamble, and the omission of the\nparenthetical \"(except as stated in this section)\" from Section 3."
         ,fillcolor="beige;1"
